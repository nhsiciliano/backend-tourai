generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GuideLanguage {
  ES_AR
  EN
}

enum GuideDuration {
  SHORT
  MEDIUM
  LONG
}

enum GuideDetailLevel {
  BASIC
  STANDARD
  DEEP
}

enum PlaceCategory {
  MONUMENT
  PLAZA
  RUIN
  SCIENTIFIC_SITE
  HISTORIC_SITE
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model User {
  id            String            @id @default(cuid())
  name          String
  email         String            @unique
  emailVerified Boolean           @default(false)
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  preferences   UserPreference?
  guideRequests GuideRequest[]
  playbacks     PlaybackHistory[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model UserPreference {
  id          String           @id @default(cuid())
  userId      String           @unique
  language    GuideLanguage    @default(ES_AR)
  duration    GuideDuration    @default(MEDIUM)
  detailLevel GuideDetailLevel @default(STANDARD)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Place {
  id                  String          @id @default(cuid())
  slug                String          @unique
  nameEs              String
  nameEn              String
  category            PlaceCategory
  city                String
  country             String
  latitude            Decimal         @db.Decimal(10, 7)
  longitude           Decimal         @db.Decimal(10, 7)
  summarySeedEs       String?
  summarySeedEn       String?
  scientificRelevance String?
  editorialScore      Int             @default(0)
  isFeatured          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  sources             PlaceSource[]
  guides              GeneratedGuide[]
  requests            GuideRequest[]

  @@map("places")
}

model PlaceSource {
  id         String   @id @default(cuid())
  placeId     String
  provider    String
  sourceUrl   String?
  externalId  String?
  createdAt   DateTime @default(now())
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId])
  @@map("place_sources")
}

model GeneratedGuide {
  id                   String           @id @default(cuid())
  placeId              String
  language             GuideLanguage
  duration             GuideDuration
  detailLevel          GuideDetailLevel
  script               String?
  provider             String?
  promptVersion        String?
  inputHash            String           @unique
  estimatedDurationSec Int?
  status               ProcessingStatus @default(PENDING)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  place                Place            @relation(fields: [placeId], references: [id], onDelete: Cascade)
  audioAssets          AudioAsset[]
  playbackHistory      PlaybackHistory[]

  @@index([placeId, language, duration, detailLevel])
  @@map("generated_guides")
}

model GuideRequest {
  id          String           @id @default(cuid())
  userId       String?
  placeId      String
  language     GuideLanguage
  duration     GuideDuration
  detailLevel  GuideDetailLevel
  source       String
  status       ProcessingStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  place        Place            @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([placeId])
  @@index([userId])
  @@map("guide_requests")
}

model AudioAsset {
  id           String           @id @default(cuid())
  guideId       String
  storageBucket String
  storagePath   String
  mimeType      String           @default("audio/mpeg")
  voiceCode     String?
  durationMs    Int?
  status        ProcessingStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  guide         GeneratedGuide   @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@map("audio_assets")
}

model PlaybackHistory {
  id         String         @id @default(cuid())
  userId      String
  guideId     String
  playedAt    DateTime       @default(now())
  completedAt DateTime?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  guide       GeneratedGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@index([guideId])
  @@map("playback_history")
}
